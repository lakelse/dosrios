---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('schedule');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, schedule, time, location, description, type, style, note } = entry.data;
const { Content } = await render(entry);
---

<Layout title={title} description={description}>
  <div class="container page-content">
    <a href="/events" class="back-link">← Back to Events</a>
    <article>
      <header class="entry-header">
        <div class="badges">
          <span class={`badge badge-${type}`}>{type}</span>
          {style && <span class={`badge badge-style-${style}`}>{style}</span>}
        </div>
        <h1>{title}</h1>
        <div class="entry-meta">
          <p class="entry-schedule">{schedule}</p>
          {note && <p class="entry-note">{note}</p>}
          <p>{time}</p>
          <p>{location}</p>
        </div>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style>
.page-content {
  padding-top: 3rem;
  padding-bottom: 5rem;
}

.back-link {
  display: inline-block;
  color: var(--text-muted);
  font-size: 0.875rem;
  margin-bottom: 2rem;
  transition: color 0.2s;
}

.back-link:hover {
  color: var(--gold);
}

.entry-header {
  margin-bottom: 2.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.badges {
  display: flex;
  gap: 0.5rem;
}

.entry-header h1 {
  font-size: 2.5rem;
  color: var(--text);
}

.entry-meta {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  font-size: 0.9rem;
  color: var(--text-muted);
  border-left: 2px solid var(--accent);
  padding-left: 1rem;
  white-space: pre-line;
}

.entry-schedule {
  color: var(--gold) !important;
  font-weight: 500;
}

.entry-note {
  color: #e8a020;
  font-size: 0.85rem;
  font-style: italic;
}
</style>
