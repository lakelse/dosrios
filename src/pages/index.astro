---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import ScheduleCard from '../components/ScheduleCard.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const upcomingEvents = allEvents
  .filter(e => new Date(e.data.date) >= new Date())
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 3);

const regularSchedule = await getCollection('schedule');

const blogPosts = await getCollection('blog');
const latestPost = blogPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)[0];
---

<Layout title="Home">
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">Winnipeg, Manitoba</p>
      <h1>Dos Ríos</h1>
      <p class="tagline">Argentine Tango & Nuevo</p>
      <p class="hero-text">
        A community for tango dancers in Winnipeg. Join us for milongas,
        practicas, and classes.
      </p>
      <div class="hero-ctas">
        <a href="/events" class="btn btn-primary">Upcoming Events</a>
        <a
          href="/discord"
          class="btn btn-discord"
        >
          Join Discord
        </a>
      </div>
    </div>
    <p class="photo-credit">Photo by <a href="https://unsplash.com/photos/KFIjzXYg1RM" target="_blank" rel="noopener noreferrer">Jeremy Bishop</a> on <a href="https://unsplash.com/" target="_blank" rel="noopener noreferrer">Unsplash</a></p>
  </section>

  <section class="section">
    <div class="container">
      <h2>Events</h2>
      <div class="events-grid">
        {upcomingEvents.map(event => <EventCard event={event} />)}
        {regularSchedule.map(entry => <ScheduleCard entry={entry} />)}
      </div>
      <a href="/events" class="see-all">See all events →</a>
    </div>
  </section>

  {latestPost && (
    <section class="section section-alt">
      <div class="container">
        <h2>From the Blog</h2>
        <a href={`/blog/${latestPost.id}`} class="blog-preview">
          <p class="blog-preview-date">
            {latestPost.data.date.toLocaleDateString('en-CA', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </p>
          <h3>{latestPost.data.title}</h3>
          <p>{latestPost.data.description}</p>
        </a>
        <a href="/blog" class="see-all">All posts →</a>
      </div>
    </section>
  )}

  <section class="section discord-cta">
    <div class="container">
      <h2>Join the Community</h2>
      <p>
        Connect with Winnipeg tango dancers on Discord — event announcements,
        music, conversation.
      </p>
      <a
        href="/discord"
        class="btn btn-discord"
      >
        Join our Discord
      </a>
    </div>
  </section>
</Layout>

<style>
.hero {
  padding: 6rem 0 5rem;
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}

.photo-credit {
  position: absolute;
  bottom: 0.5rem;
  right: 0.75rem;
  z-index: 2;
  font-size: 0.65rem;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.03em;
}

.photo-credit a {
  color: rgba(255, 255, 255, 0.4);
  text-decoration: underline;
}

.photo-credit a:hover {
  color: rgba(255, 255, 255, 0.7);
}

.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url('/winnipeg.avif');
  background-size: 120% auto;
  background-position: center bottom;
  z-index: 0;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    to right,
    rgba(13, 13, 13, 0.92) 0%,
    rgba(13, 13, 13, 0.75) 50%,
    rgba(13, 13, 13, 0.4) 100%
  );
}

@media (max-width: 640px) {
  .hero {
    min-height: 60vw;
  }

  .hero::after {
    background-size: cover;
    background-position: center;
  }

  .hero::before {
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 13, 0.85) 0%,
      rgba(13, 13, 13, 0.5) 50%,
      rgba(13, 13, 13, 0.75) 100%
    );
  }
}

.hero .container {
  position: relative;
  z-index: 2;
}

.hero-eyebrow {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}

.hero h1 {
  font-size: clamp(3.5rem, 8vw, 6rem);
  color: var(--gold);
  line-height: 1;
  margin-bottom: 0.25rem;
}

.tagline {
  font-family: 'Playfair Display', Georgia, serif;
  font-style: italic;
  font-size: 1.25rem;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}

.hero-text {
  max-width: 480px;
  color: #c0b8a8;
  margin-bottom: 2rem;
  font-size: 1.05rem;
  line-height: 1.7;
}

.hero-ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.events-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.25rem;
}

.blog-preview {
  display: block;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 1.5rem;
  max-width: 600px;
  text-decoration: none;
  transition: border-color 0.2s;
}

.blog-preview:hover {
  border-color: var(--gold);
}

.blog-preview-date {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.blog-preview h3 {
  font-size: 1.3rem;
  color: var(--text);
  margin-bottom: 0.5rem;
}

.blog-preview p {
  color: #a09890;
  font-size: 0.9rem;
  line-height: 1.5;
}

.discord-cta {
  text-align: center;
}

.discord-cta h2 {
  margin-bottom: 0.75rem;
}

.discord-cta p {
  color: var(--text-muted);
  max-width: 480px;
  margin: 0 auto 1.5rem;
}
</style>
