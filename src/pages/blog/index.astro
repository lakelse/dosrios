---
import Layout from '../../layouts/Layout.astro';
import PageBanner from '../../components/PageBanner.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sorted = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog" description="Writings on tango, music, and community from Dos Ríos.">
  <PageBanner title="Blog" subtitle="Writings on tango, music, and community." />

  <div class="container page-content">
    {sorted.length === 0 ? (
      <p class="empty">No posts yet. Check back soon.</p>
    ) : (
      <ul class="post-list">
        {sorted.map(post => (
          <li>
            <a href={`/blog/${post.id}`} class="post-item">
              <span class="post-date">
                {post.data.date.toLocaleDateString('en-CA', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </span>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="tags">
                  {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>

<style>
.page-content {
  padding-top: 3rem;
  padding-bottom: 5rem;
}

.post-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.post-item {
  display: block;
  padding: 1.75rem 0;
  border-bottom: 1px solid var(--border);
  text-decoration: none;
}

.post-date {
  font-size: 0.8rem;
  color: var(--text-muted);
  display: block;
  margin-bottom: 0.4rem;
}

.post-item h2 {
  font-size: 1.4rem;
  color: var(--text);
  margin-bottom: 0.5rem;
  transition: color 0.2s;
}

.post-item:hover h2 {
  color: var(--gold);
}

.post-item p {
  color: #a09890;
  font-size: 0.9rem;
  line-height: 1.5;
}

.tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-top: 0.75rem;
}

.tag {
  font-size: 0.75rem;
  padding: 0.15rem 0.5rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 3px;
  color: var(--text-muted);
}

.empty {
  color: var(--text-muted);
}
</style>
